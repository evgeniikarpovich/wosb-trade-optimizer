{
  "name": "wosb-trade-optimizer",
  "version": "0.1.0",
  "description": "World of Sea Battle trade-route profit optimizer (bounded knapsack) + web UI.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p web/tsconfig.json",
    "demo": "tsx scripts/demo.ts",
    "license:check": "license-checker-rseidelsohn --onlyAllow \"MIT;MIT-0;ISC;0BSD;BSD-2-Clause;BSD-3-Clause;Apache-2.0;Apache*;BlueOak-1.0.0;MPL-2.0;CC0-1.0;CC-BY-4.0;CC-BY-3.0;(MIT AND CC-BY-3.0);Unlicense;Python-2.0;WTFPL\" --excludePrivatePackages --summary",
    "license:report": "license-checker-rseidelsohn --excludePrivatePackages --json --out THIRD-PARTY-LICENSES.json"
  },
  "keywords": ["knapsack", "optimization", "trade", "game", "react"],
  "license": "MIT",
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "license-checker-rseidelsohn": "^4.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
